datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String      @id @default(cuid())
  name          String?
  email         String      @unique
  emailVerified DateTime?
  image         String?
  password      String
  role          String      @default("CUSTOMER")
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  quotes        QuoteRequest[]
  createdAt     DateTime    @default(now())
}

model Account {
  id                 String   @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  oauth_token_secret String?
  oauth_token        String?
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Product {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  description String
  category    String
  price       Float
  power       String
  efficiency  String
  warranty    String
  rating      Float
  availability String
  country     String
  image       String
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
}

model Order {
  id               String      @id @default(cuid())
  status           String      @default("PENDING")
  total            Float
  currency         String      @default("USD")
  paymentIntent    String?
  shippingAddress  String?
  user             User        @relation(fields: [userId], references: [id])
  userId           String
  items            OrderItem[]
  installationJobs InstallationJob[]
  createdAt        DateTime    @default(now())
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  unitPrice Float
  product   Product @relation(fields: [productId], references: [id])
  productId String
  order     Order   @relation(fields: [orderId], references: [id])
  orderId   String
}

model QuoteRequest {
  id               String   @id @default(cuid())
  name             String
  email            String
  phone            String
  country          String
  electricityBill  Float
  roofArea         Float
  preferredTimeline String
  message          String?
  user             User?    @relation(fields: [userId], references: [id])
  userId           String?
  createdAt        DateTime @default(now())
}

model Installer {
  id        String              @id @default(cuid())
  name      String
  region    String
  rating    Float
  available Boolean             @default(true)
  jobs      InstallationJob[]
  createdAt DateTime            @default(now())
}

model InstallationJob {
  id           String    @id @default(cuid())
  status       String    @default("ASSIGNED")
  scheduledAt  DateTime
  address      String
  customerName String
  installer    Installer @relation(fields: [installerId], references: [id])
  installerId  String
  order        Order?    @relation(fields: [orderId], references: [id])
  orderId      String?
  createdAt    DateTime  @default(now())
}
